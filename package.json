{
  "name": "git-change-lists",
  "displayName": "Git Change Lists",
  "description": "JetBrains-style Change Lists for VS Code - organize your changes into named lists for focused commits",
  "icon": "static/icon.png",
  "version": "1.0.0",
  "publisher": "maxie-homrich",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "scm",
    "changelist",
    "commit"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "views": {
      "scm": [
        {
          "id": "gitChangeLists.changeLists",
          "name": "Change Lists",
          "when": "gitOpenRepositoryCount > 0",
          "contextualTitle": "Git Change Lists"
        }
      ]
    },
    "commands": [
      {
        "command": "gitChangeLists.createList",
        "title": "Create Change List",
        "category": "Git Change Lists",
        "icon": "$(add)"
      },
      {
        "command": "gitChangeLists.deleteList",
        "title": "Delete Change List",
        "category": "Git Change Lists",
        "icon": "$(trash)"
      },
      {
        "command": "gitChangeLists.renameList",
        "title": "Rename Change List",
        "category": "Git Change Lists",
        "icon": "$(edit)"
      },
      {
        "command": "gitChangeLists.setActiveList",
        "title": "Set as Active Change List",
        "category": "Git Change Lists",
        "icon": "$(check)"
      },
      {
        "command": "gitChangeLists.moveToList",
        "title": "Move to Change List",
        "category": "Git Change Lists",
        "icon": "$(move)"
      },
      {
        "command": "gitChangeLists.commitList",
        "title": "Commit Change List",
        "category": "Git Change Lists",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitChangeLists.stageList",
        "title": "Stage Change List",
        "category": "Git Change Lists",
        "icon": "$(diff-added)"
      },
      {
        "command": "gitChangeLists.toggleViewMode",
        "title": "Toggle List/Tree View",
        "category": "Git Change Lists",
        "icon": "$(list-tree)"
      },
      {
        "command": "gitChangeLists.applyPatch",
        "title": "Apply Patch to Change List",
        "category": "Git Change Lists",
        "icon": "$(diff)"
      },
      {
        "command": "gitChangeLists.createPatch",
        "title": "Create Patch from Change List",
        "category": "Git Change Lists",
        "icon": "$(export)"
      },
      {
        "command": "gitChangeLists.refresh",
        "title": "Refresh Change Lists",
        "category": "Git Change Lists",
        "icon": "$(refresh)"
      },
      {
        "command": "gitChangeLists.guardedCommit",
        "title": "Commit (with Guard)",
        "category": "Git Change Lists",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitChangeLists.setListColor",
        "title": "Set Change List Color",
        "category": "Git Change Lists",
        "icon": "$(paintcan)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitChangeLists.createList",
          "when": "view == gitChangeLists.changeLists",
          "group": "navigation@1"
        },
        {
          "command": "gitChangeLists.toggleViewMode",
          "when": "view == gitChangeLists.changeLists",
          "group": "navigation@2"
        },
        {
          "command": "gitChangeLists.refresh",
          "when": "view == gitChangeLists.changeLists",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "gitChangeLists.setActiveList",
          "when": "view == gitChangeLists.changeLists && viewItem =~ /^changeList/ && viewItem != changeListActive && viewItem != changeListReadOnly",
          "group": "1_state@1"
        },
        {
          "command": "gitChangeLists.stageList",
          "when": "view == gitChangeLists.changeLists && viewItem =~ /^changeList/",
          "group": "2_actions@1"
        },
        {
          "command": "gitChangeLists.commitList",
          "when": "view == gitChangeLists.changeLists && viewItem =~ /^changeList/",
          "group": "2_actions@2"
        },
        {
          "command": "gitChangeLists.applyPatch",
          "when": "view == gitChangeLists.changeLists && viewItem =~ /^changeList/",
          "group": "2_actions@3"
        },
        {
          "command": "gitChangeLists.createPatch",
          "when": "view == gitChangeLists.changeLists && viewItem =~ /^changeList/",
          "group": "2_actions@4"
        },
        {
          "command": "gitChangeLists.renameList",
          "when": "view == gitChangeLists.changeLists && viewItem =~ /^changeList/ && viewItem != changeListReadOnly",
          "group": "3_edit@1"
        },
        {
          "command": "gitChangeLists.setListColor",
          "when": "view == gitChangeLists.changeLists && viewItem =~ /^changeList/ && viewItem != changeListReadOnly",
          "group": "3_edit@2"
        },
        {
          "command": "gitChangeLists.deleteList",
          "when": "view == gitChangeLists.changeLists && viewItem =~ /^changeList/ && viewItem != changeListDefault && viewItem != changeListReadOnly",
          "group": "3_edit@2"
        },
        {
          "command": "gitChangeLists.moveToList",
          "when": "view == gitChangeLists.changeLists && viewItem == changeListFile",
          "group": "1_move@1"
        }
      ],
      "commandPalette": [
        {
          "command": "gitChangeLists.deleteList",
          "when": "false"
        },
        {
          "command": "gitChangeLists.renameList",
          "when": "false"
        },
        {
          "command": "gitChangeLists.commitList",
          "when": "false"
        },
        {
          "command": "gitChangeLists.stageList",
          "when": "false"
        },
        {
          "command": "gitChangeLists.createPatch",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "gitChangeLists.setActiveList",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "view == gitChangeLists.changeLists"
      },
      {
        "command": "gitChangeLists.moveToList",
        "key": "alt+shift+m",
        "when": "view == gitChangeLists.changeLists && viewItem == changeListFile"
      },
      {
        "command": "gitChangeLists.guardedCommit",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "scmRepository && config.gitChangeLists.commitGuard.interceptCommit && scmInputIsFocused"
      }
    ],
    "configuration": {
      "title": "Git Change Lists",
      "properties": {
        "gitChangeLists.defaultViewMode": {
          "type": "string",
          "enum": [
            "list",
            "tree"
          ],
          "default": "list",
          "description": "Default view mode for displaying files in change lists"
        },
        "gitChangeLists.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the active change list in the status bar"
        },
        "gitChangeLists.confirmDeleteNonEmpty": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before deleting a non-empty change list"
        },
        "gitChangeLists.autoActivateNew": {
          "type": "boolean",
          "default": true,
          "description": "Automatically set newly created change lists as active"
        },
        "gitChangeLists.commitGuard.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Warn when attempting to commit files from multiple change lists"
        },
        "gitChangeLists.commitGuard.interceptCommit": {
          "type": "boolean",
          "default": false,
          "description": "Intercept the native Git commit command to apply the commit guard (requires restart)"
        },
        "gitChangeLists.autoAssignStagedFiles": {
          "type": "boolean",
          "default": true,
          "description": "Automatically assign externally staged files to the active change list"
        },
        "gitChangeLists.debug.enableLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging to the output channel (verbose)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.x",
    "typescript": "^5.x"
  },
  "dependencies": {
    "simple-git": "^3.x",
    "uuid": "^9.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maxinne-dev/vscode-git-change-lists"
  },
  "license": "AGPL-3.0-only"
}